@page
@model WebApp.Pages.ProductModel
@{
}

<script src="~/js/ControlActions.js"></script>
<script src="~/js/Pages/ProductViewController.js"></script>


<h1>Lista de Productos</h1>

<div class="row">
    <legend>Listado</legend>

    <div class="col-lg-12">

        <table id="tblProducts" class="display" style="width:100%">
            <thead>
                <tr>
                    <th>id</th>
                    <th>Nombre</th>
                    <th>Categoria</th>
                    <th>Cantidad</th>
                    <th>Precio</th>
                    <th>estado</th>
                    <th>fecha creacion</th>
                </tr>
            </thead>
        </table>
    </div>
</div>



<div class="row">
    <div class="col-lg-6 mx-auto">
        <div class="bs-component">
            <form>
                <fieldset>
                    <legend>Edicion</legend>
                    <div class="form-group">
                        <label form="txtId" class="form-label mt-4">ID</label>
                        <input id="txtId" type="number" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label form="txtName" class="form-label mt-4">Nombre</label>
                        <input id="txtName" type="text" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label form="txtCategory" class="form-label mt-4">Categoria</label>
                        <input id="txtCategory" type="text" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label form="txtQuantity" class="form-label mt-4">Cantidad</label>
                        <input id="txtQuantity" type="number" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label form="txtPrice" class="form-label mt-4">Precio</label>
                        <input id="txtPrice" type="number" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label form="txtStatus" class="form-label mt-4">Estado</label>
                        <input id="txtStatus" type="text" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label for="txtDescription" class="form-label mt-4">Descripcion</label>
                        <input id="txtDescription" type="text" class="form-control" />
                    </div>
                </fieldset>
            </form>
            <br />
            <button id="btnCreate" class="btn btn-primary btn-xs" type="button">Crear</button>
            <button id="btnUpdate" class="btn btn-secondary btn-xs" type="button">Actualizar</button>
            <button id="btnDelete" class="btn btn-danger btn-xs" type="button">Eliminar</button>
        </div>
    </div>
</div>


